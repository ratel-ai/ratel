{
  "name": "@ratel-ai/sdk",
  "version": "0.3.0-rc.2",
  "description": "TypeScript SDK for Ratel — context engineering platform for AI agents. BM25 tool retrieval, MCP ingestion, framework-neutral gateway tools.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Agentified",
  "homepage": "https://github.com/ratel-ai/ratel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ratel-ai/ratel.git",
    "directory": "src/sdk/ts"
  },
  "bugs": {
    "url": "https://github.com/ratel-ai/ratel/issues"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "tool-calling",
    "bm25",
    "retrieval",
    "context-engineering",
    "ratel"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "native/index.cjs",
    "native/index.d.cts",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --manifest-path native/Cargo.toml --output-dir native --js index.cjs --dts index.d.cts",
    "build:ts": "tsc",
    "build": "pnpm build:native && pnpm build:ts",
    "typecheck": "pnpm build:native && tsc --noEmit",
    "lint": "biome check src",
    "test": "pnpm build:native && vitest run"
  },
  "napi": {
    "binaryName": "ratel-sdk",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@napi-rs/cli": "^3.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/json-schema": "^7.0.15"
  }
}
