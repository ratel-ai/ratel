{
  "name": "agentified",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agentified monorepo - npm packages for agent development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentified/agentified.git"
  },
  "bugs": {
    "url": "https://github.com/agentified/agentified/issues"
  },
  "homepage": "https://github.com/agentified/agentified#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^20.17.12",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
