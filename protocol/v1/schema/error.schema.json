{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ratel.sh/protocol/v1/error.schema.json",
  "title": "Error",
  "description": "The uniform body of every non-2xx /v1 response.",
  "type": "object",
  "required": ["error"],
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "enum": ["unauthorized", "not_found", "invalid_request", "unavailable"] },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
