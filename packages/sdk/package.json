{
  "name": "@agentified/sdk",
  "version": "0.0.1",
  "description": "Platform API client for Agentified",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentified/agentified.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/agentified/agentified/issues"
  },
  "homepage": "https://github.com/agentified/agentified/tree/main/packages/sdk#readme"
}
