{
  "name": "@agentified/cli",
  "version": "0.0.0",
  "description": "Developer CLI for Agentified",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentified": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentified/runtime": "workspace:*",
    "@agentified/sdk": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentified/agentified.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/agentified/agentified/issues"
  },
  "homepage": "https://github.com/agentified/agentified/tree/main/packages/cli#readme"
}
