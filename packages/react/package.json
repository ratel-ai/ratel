{
  "name": "@agentified/react",
  "version": "0.0.1",
  "description": "React hooks and components for Agentified",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@agentified/sdk": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@agentified/sdk": "workspace:*",
    "@types/react": "^18.3.18",
    "jsdom": "^26.0.0",
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentified/agentified.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/agentified/agentified/issues"
  },
  "homepage": "https://github.com/agentified/agentified/tree/main/packages/react#readme"
}
