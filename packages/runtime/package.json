{
  "name": "@agentified/runtime",
  "version": "0.0.2",
  "description": "Agent execution from config using Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24",
    "yaml": "^2.7"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "@ai-sdk/openai": ">=1.0.0",
    "@ai-sdk/anthropic": ">=1.0.0",
    "@ai-sdk/google": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": { "optional": true },
    "@ai-sdk/anthropic": { "optional": true },
    "@ai-sdk/google": { "optional": true }
  },
  "devDependencies": {
    "ai": "^4.1.0",
    "@ai-sdk/openai": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentified/agentified.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/agentified/agentified/issues"
  },
  "homepage": "https://github.com/agentified/agentified/tree/main/packages/runtime#readme"
}
